# VARIABLES DE ENTORNO - FIREBASE & SEGURIDAD
# Copia este archivo a .env y rellena con tus valores reales
# NUNCA commits .env al repositorio

# Firebase Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_auth_domain
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# reCAPTCHA v3 (Site Key es PÚBLICA)
RECAPTCHA_SITE_KEY=6LeQc_4sAAAAAJ-4HbwcfBcUAA5faSRGrYzo9hoP
RECAPTCHA_SECRET_KEY=your_secret_recaptcha_key_KEEP_PRIVATE

# Admin Credentials (SOLO para desarrollo local)
ADMIN_EMAIL=your_test_admin_email@example.com
ADMIN_PASSWORD=your_test_admin_password

# Ambiente
ENVIRONMENT=development
DEBUG=false
